# Postgres connection string (e.g. a Neon database).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"


# better-auth server secret — generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of your app (used by better-auth on the server)
BETTER_AUTH_URL=http://localhost:3000

# Same base URL, exposed to the browser auth client
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub OAuth app credentials (https://github.com/settings/developers)
# Authorization callback URL must be: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App credentials (https://github.com/settings/apps — a separate app from
# the OAuth one above). Drives the install flow on /dashboard/github.
#   - Setup / callback URL must be: http://localhost:3000/api/github/callback
#   - APP_NAME is the app's URL slug (github.com/apps/<slug>)
#   - PRIVATE_KEY: paste the PEM as a single line with literal \n between lines,
#     e.g. GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"
GITHUB_APP_ID=
GITHUB_APP_NAME=
GITHUB_APP_PRIVATE_KEY=

# The secret GitHub signs webhook deliveries with. Required for the PR webhook
# (app/api/github/webhook) to accept events — set it on the GitHub App and here.
GITHUB_WEBHOOK_SECRET=

# Inngest (background jobs). Optional in local dev: run `npx inngest-cli@latest dev`
# alongside `next dev` and neither key is needed. Set these only in deployed envs.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
