# Postgres connection string (e.g. a Neon database).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"


# better-auth server secret — generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Base URL of your app (used by better-auth on the server)
BETTER_AUTH_URL=http://localhost:3000

# Same base URL, exposed to the browser auth client
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub OAuth app credentials (https://github.com/settings/developers)
# Authorization callback URL must be: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
